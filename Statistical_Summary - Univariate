        "\n",
        "    # 5. Number of Unique Values\n",
        "    num_unique = df[col].nunique()\n",
        "    print(f\"Number of Unique Values: {num_unique}\")\n",
        "\n",
        "    # 6. Number of Missing Values\n",
        "    missing_values = df[col].isnull().sum()\n",
        "    print(f\"Number of Missing Values: {missing_values}\")\n"
