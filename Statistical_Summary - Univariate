        "    plt.xlabel(col)\n",
        "    plt.ylabel('Count')\n",
        "    plt.xticks(rotation=45, ha='right')\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "\n",
        "    # 3. Relative Frequency\n",
        "    relative_freq = df[col].value_counts(normalize=True)\n",
        "    print(\"Relative Frequency:\")\n",
        "    display(relative_freq)\n",
        "\n",
        "    # 4. Mode\n",
        "    mode_value = df[col].mode()\n",
