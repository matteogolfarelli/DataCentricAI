        "\n",
        "for col in categorical_cols:\n",
        "    print(f\"\\n--- Analysis for column: '{col}' ---\")\n",
        "\n",
        "    # 1. Frequency Count\n",
        "    freq_count = df[col].value_counts()\n",
        "    print(\"Frequency Count:\")\n",
        "    display(freq_count)\n",
        "\n",
        "    # 2. Bar Chart\n",
